{
  "name": "@fullstackhouse/open-mercato-health",
  "version": "0.2.2",
  "description": "Health check endpoints for Open Mercato applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./strategies": {
      "types": "./dist/strategies/index.d.ts",
      "default": "./dist/strategies/index.js"
    },
    "./handlers": {
      "types": "./dist/handlers/index.d.ts",
      "default": "./dist/handlers/index.js"
    },
    "./integrations/nextjs": {
      "types": "./dist/integrations/nextjs.d.ts",
      "default": "./dist/integrations/nextjs.js"
    },
    "./modules/health/index": {
      "types": "./dist/modules/health/index.d.ts",
      "default": "./dist/modules/health/index.js"
    },
    "./modules/health/api/get/live": {
      "types": "./dist/modules/health/api/get/live.d.ts",
      "default": "./dist/modules/health/api/get/live.js"
    },
    "./modules/health/api/get/ready": {
      "types": "./dist/modules/health/api/get/ready.d.ts",
      "default": "./dist/modules/health/api/get/ready.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@mikro-orm/postgresql": ">=6.0.0",
    "@open-mercato/cache": "*",
    "@open-mercato/shared": "*",
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "@mikro-orm/postgresql": {
      "optional": true
    },
    "@open-mercato/cache": {
      "optional": true
    },
    "@open-mercato/shared": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/postgresql": "^6.0.0",
    "@open-mercato/cache": "*",
    "@open-mercato/shared": "*",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "next": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "health-check",
    "kubernetes",
    "open-mercato",
    "readiness",
    "liveness"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fullstackhouse/open-mercato-health.git"
  },
  "author": "Full Stack House",
  "license": "MIT"
}
